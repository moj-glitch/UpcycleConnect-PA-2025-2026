FROM golang:1.23-alpine AS build
WORKDIR /src

COPY api/go.mod api/go.sum ./
RUN go mod download

COPY api/. .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/api .

FROM alpine:3.21
RUN apk add --no-cache ca-certificates
WORKDIR /app
COPY --from=build /out/api /app/api

RUN mkdir -p /data
ENV DATA_DIR=/data
EXPOSE 8080
VOLUME ["/data"]
ENTRYPOINT ["/app/api"]
